rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: pranks
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 1000 chars)
    //   - content: string (required, < 1000000 chars)
    //   - tags: list of strings (required, < 50 items)
    //   - status: string (required, in ['NOVAS', 'VOU_FAZER', 'BOA', 'DESCARTADAS'])
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //   - movedToDiscardedAt: timestamp (optional)
    //   - isArchived: boolean (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidList(list, maxSize) {
      return list is list && list.size() <= maxSize;
    }

    function isValidPrank(data) {
      return hasRequiredFields(['title', 'content', 'tags', 'status', 'createdAt', 'updatedAt', 'isArchived']) &&
             validStringLength('title', 1, 1000) &&
             validStringLength('content', 0, 1000000) &&
             isValidList(data.tags, 50) &&
             data.status in ['NOVAS', 'VOU_FAZER', 'BOA', 'DESCARTADAS'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.isArchived is bool &&
             (!('movedToDiscardedAt' in data) || data.movedToDiscardedAt == null || data.movedToDiscardedAt is timestamp);
    }

    match /pranks/{prankId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPrank(request.resource.data);
      allow update: if isAuthenticated() && isValidPrank(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
